name: Container Workflow
on: workflow_dispatch:

env:
  ACR_LOGIN_SERVER: aistraining.azurecr.io
  ACR_USERNAME: ${{ secrets.ACR_USERNAME }}
  ACR_PASSWORD: ${{ secrets.ACR_PASSWORD }}
  TAG_NAME: eshoponweb-webapp-user010:1.0.0
  
  
jobs:
  build:
    runs-on: ubuntu-latest
    steps:
      - name: Checkout repository
        uses: actions/checkout@v7.0.0

      - name: ACR Login
        uses: azure/docker-login@v4.4.0
        with:
          login-server: ${{ env.ACR_LOGIN_SERVER }}
          username: ${{ env.ACR_USERNAME }}
          password: ${{ env.ACR_PASSWORD }}

      - name: Build and push Docker image
        uses: docker/build-push-action@v5
        run: |
          docker build . -t ${{ env.ACR_LOGIN_SERVER }}/${{ env.TAG_NAME }}
          docker push ${{ env.ACR_LOGIN_SERVER }}/${{ env.TAG_NAME }}
